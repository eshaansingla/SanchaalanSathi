rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Tasks ────────────────────────────────────────────────────────────────
    // Authenticated users can read tasks (volunteer feed).
    // All writes are server-side only via Admin SDK — clients never write tasks.
    match /tasks/{taskId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Volunteers ───────────────────────────────────────────────────────────
    // Any authenticated user can read volunteer profiles (needed for task feed).
    // A volunteer may only write their own profile document.
    match /volunteers/{volId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == volId;
    }

    // ── Needs ────────────────────────────────────────────────────────────────
    // Read-only for authenticated users.
    // Needs are created exclusively by the ingest pipeline (Admin SDK).
    match /needs/{needId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Activity feed ────────────────────────────────────────────────────────
    // Read-only for authenticated users. Written by backend Admin SDK only.
    match /activity/{eventId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Each user can only read their own notifications.
    // Written by backend Admin SDK only — no client writes permitted.
    match /notifications/{notifId} {
      allow read:  if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Default deny ────────────────────────────────────────────────────────
    // All collections not explicitly listed above are fully denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
