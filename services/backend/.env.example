# Backend environment

# Database
DATABASE_URL=postgresql+asyncpg://postgres.zpdhpbynbfisdkeydvwt:<PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# JWT auth for backend-issued access tokens
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Gemini / other integrations
GEMINI_API_KEY=
GEOAPIFY_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
NEO4J_NOTIFICATIONS_LOG_LEVEL=WARNING

# Realtime + optional Redis cache
CLIENT_URL=http://localhost:3000
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=
REDIS_LOCATION_TTL_SECONDS=120
ENABLE_DYNAMIC_REASSIGNMENT=true
REASSIGNMENT_MOVE_THRESHOLD_KM=0.2
