# ── Backend environment variables ───────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── Deployment ────────────────────────────────────────────────────────────────
DEPLOYMENT_ENV=development        # development | staging | production
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=                  # comma-separated extra CORS origins

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/synapseai
DB_NAME=synapseai
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars

# ── Google Gemini (chatbot + entity extraction) ───────────────────────────────
# REQUIRED for chatbot. Both names accepted; GEM_KEY takes precedence.
GEM_KEY=your-gemini-api-key-here
GEMINI_API_KEY=                   # fallback if GEM_KEY not set

# Chatbot cost controls
USER_DAILY_TOKEN_LIMIT=20000
GLOBAL_TPM_LIMIT=50000

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Neo4j (knowledge graph) ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# Distance matrix + location cache TTL (seconds)
LOCATION_CACHE_TTL_SECONDS=120

# ── Geoapify routing (optional — falls back to haversine) ─────────────────────
GEOAPIFY_API_KEY=

# ── Realtime / Location ───────────────────────────────────────────────────────
ENABLE_DYNAMIC_REASSIGNMENT=true
REASSIGNMENT_MOVE_THRESHOLD_KM=0.2

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_GUEST_MODE=true            # set false in production to disable demo accounts
